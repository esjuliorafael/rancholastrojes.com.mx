# ─── Ignorar contenido de carpetas sensibles ───
assets/images/**
assets/uploads/**
config/**

# ─── Permitir que Git entre a los directorios ───
!assets/images/
!assets/uploads/
!config/

# ─── Permitir subdirectorios (un nivel) ───
!assets/images/*/
!assets/uploads/*/
!config/*/

# ─── Permitir subdirectorios anidados (dos niveles) ───
!assets/images/*/*/

# ─── Conservar los .gitkeep en cualquier nivel ───
!**/.gitkeep